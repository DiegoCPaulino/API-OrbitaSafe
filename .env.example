ORACLE_URL=jdbc:oracle:thin:@oracle.fiap.com.br:1521:orcl
ORACLE_USER=seu_rm_aqui
ORACLE_PASSWORD=sua_senha_aqui

# IA — REAL chama a API Flask; MOCK usa o avaliador interno (default)
IA_MODO=MOCK
# Endpoint COMPLETO de predicao da Flask (com o caminho), usado quando IA_MODO=REAL
IA_URL=https://sua-api-flask.exemplo.com/prever

# Fonte de clima — SIMULADO (default) usa cenarios do banco; OPEN_METEO usa a API real
FONTE_CLIMA=SIMULADO
# Opcional: fixa um cenario por id no modo SIMULADO (1-6); sem isso, rotaciona
# CENARIO_FIXO=5